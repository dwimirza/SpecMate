generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model CPU {
  id         Int      @id @default(autoincrement())
  brand      String
  model      String
  slug       String   @unique
  benchmark  Int?
  singleCore Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  laptops    Laptop[]

  @@unique([brand, model])
}

model GPU {
  id        Int      @id @default(autoincrement())
  brand     String
  model     String
  slug      String   @unique
  benchmark Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  laptops   Laptop[]

  @@unique([brand, model])
}

model Phone {
  id                  Int      @id @default(autoincrement())
  brand               String
  model               String
  slug                String   @unique
  soc                 String?
  ramGb               Int?
  storageGb           Int?
  batteryMah          Int?
  batteryHours        Float?
  benchmark           Int?
  priceIdr            Int?
  screenSizeInch      Float?
  screenResolutionX   Int?
  screenResolutionY   Int?
  screenPanelType     String?
  screenRefreshRateHz Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([brand, model])
}

model Laptop {
  id                  Int      @id @default(autoincrement())
  brand               String
  model               String
  slug                String   @unique
  cpuId               Int?
  gpuId               Int?
  ramGb               Int?
  storageGb           Int?
  batteryWh           Float?
  batteryHours        Float?
  priceIdr            Int?
  screenSizeInch      Float?
  screenResolutionX   Int?
  screenResolutionY   Int?
  screenPanelType     String?
  screenRefreshRateHz Int?
  imageUrl            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  cpu                 CPU?     @relation(fields: [cpuId], references: [id])
  gpu                 GPU?     @relation(fields: [gpuId], references: [id])

  @@unique([brand, model])
  @@index([cpuId])
  @@index([gpuId])
}
