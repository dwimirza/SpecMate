// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model Phone {
  id          Int     @id @default(autoincrement())
  brand       String
  model       String
  soc         String?   // chipset / CPU
  ramGb       Int?
  storageGb   Int?
  batteryMah  Int?
  benchmark   Int?      // AnTuTu / Geekbench approximated
  priceIdr    Int?
}

model Laptop {
  id          Int     @id @default(autoincrement())
  brand       String
  model       String
  cpu         String?
  gpu         String?
  ramGb       Int?
  storageGb   Int?
  benchmark   Int?      // PassMark / Cinebench
  priceIdr    Int?
}
